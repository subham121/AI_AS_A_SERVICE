@startuml
title PackManager Lifecycle Sequence
autonumber
hide footbox
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 20
skinparam BoxPadding 10
actor User
participant "AI Gateway" as Gateway
participant "MeteringService" as meter
participant "CapabilityRouter" as cap_router
participant "IntentManager" as intent_manager
participant "PackManager" as PM
database "PackRegistry" as Registry
database "RollbackRegistry" as RollRegistry
participant "PackServer\n(Cloud)" as PackCloud
participant "PackRunner" as Plugin
participant "AI Pack" as AIPack
participant "AI Capability Provider" as cap_provider
== Discovery And Selection Phase ==
Gateway -> PM: initialize()
PM -> PackCloud: getCapabilityList()
PackCloud --> PM: capabilityList
PM -> Registry: updateCapabilities(capabilityList)
Registry --> PM: updated
User -> Gateway: user/app(input)
Gateway -> cap_router: invoke(input)
cap_router -> intent_manager: identifyIntent(input)
intent_manager --> cap_router: skill identified
cap_router -> PM: getCapabilityList()
PM --> cap_router: capability_list
cap_router -> cap_router: normalizeCapability(skill, capabilityList)
cap_router -> PM: getLocalPacks(capability)
PM --> cap_router: pack_list

 alt Local Pack Found
  PM -> Registry: checkPackInstallation(pack_id)
  Registry --> PM: installed / not installed
  alt Pack Installed
   PM -> PM: isEnabled()
    alt Pack Enabled
      note over PM,Registry
        Pack is already installed and ready to use.
      end note
    else Pack Disabled
      PM --> Gateway: publish(pack_disabled, pack_id)
      Gateway --> User: pack is currently disabled, Enable it to use
    end
  else Pack Not Installed
   PM -> PM: installPack(pack_id)
  end
 else No Local Pack
  cap_router-> cap_provider: getDeviceCapability()
  cap_provider --> cap_router: device capabilities  
  cap_router-> PackCloud: getCompatibleCloudPacks(capability, device_capability)
  PackCloud --> cap_router: cloud compatible packs
  cap_router--> Gateway: compatible packs list\n(pack_info)
  Gateway--> User: showPackListAndRequestSelection()
  User -> Gateway: usePack(pack_id)
  Gateway -> cap_router: usePack(pack_id)
 end
 == Installation Phase ==
  cap_router-> PM: installPack(pack_id)
  PM -> PackCloud: getPackDetails(pack_id)
  PackCloud --> PM: json(URL + pack metadata(md5sum, capability, dependencies, etc.))

  PM -> PackCloud: downloadPack(pack_url)
  PackCloud --> PM: package content
  PM -> Registry: stageDownloadedPack(pack_id)
  Registry --> PM: staged package reference
  PM -> PM: verifyMD5(staged package, md5sum)
  alt MD5 verified
    loop Resolve each dependency
      PM -> PM: install(dependency_id)
    end
    PM -> Registry: installFromStage(pack_id, version)
    PM -> PM: install(pack.ipk)
    PM -> Registry: registerPack(pack_id, version)
    PM -> Registry: updateStatus(pack_id, Installed)
    Registry --> PM: OK
    PM --> Gateway: publish(pack_installed, pack_id)
  else MD5 verification failed
    PM -> Registry: discardStagedPack(pack_id)
    Registry --> PM: staged package removed
    PM -> Registry: updateStatus(pack_id, InstallFailed)
    Registry --> PM: OK
    PM --> Gateway: publish(pack_download_verification_failed, pack_id)
    Gateway --> User: installation failed due to checksum mismatch
 == Enable Phase ==
note over Gateway
  Pack should be enabled by User or MeteringService
end note
 Gateway -> PM: enablePack(pack_id)
 PM -> Registry: checkPackState(pack_id)
 Registry --> PM: Installed / Disabled
 PM -> Registry: updateStatus(pack_id, Enabled)
 Registry --> PM: OK
 PM --> Gateway: publish(pack_enabled, pack_id)
 == Loading Phase ==
 meter -> PM: activate(pack_id)
 PM -> PM: loadPack(pack_id)
 PM -> Registry: checkPackState(pack_id)
 Registry --> PM: Enabled / Disabled
 alt Pack Disabled
   PM --> Gateway: publish(pack_load_failed_disabled, pack_id)
   Gateway --> User: pack is disabled, cannot load
 else Pack Enabled
  PM -> Registry: getPack(pack_id)
  Registry --> PM: pack metadata + pack_abi_version
  PM -> Plugin: validateABI(pack_id, pack_abi_version)
  Plugin -> AIPack: getABIInfo()
  AIPack --> Plugin: pack_abi_version / exported ABI
  Plugin --> PM: ABI compatible / incompatible
  alt ABI compatible
    PM -> Plugin: initializePack(pack_id)
    Plugin -> AIPack: initialize()
    AIPack --> Plugin: status OK / activation failed
    alt Activation successful
      Plugin --> PM: initialized
      PM -> Registry: updateStatus(pack_id, Loaded)
      Registry --> PM: OK
      PM --> Gateway: publish(pack_loaded, pack_id)
    else Activation failed
      Plugin --> PM: activation failed
      PM -> Registry: updateStatus(pack_id, activation_failed)
      Registry --> PM: OK
      PM --> Gateway: publish(pack_activation_failed, pack_id)
      Gateway --> User: pack activation failed
    end
  else ABI incompatible
    PM -> Registry: updateStatus(pack_id, incompatible_abi)
    Registry --> PM: OK
    PM --> Gateway: publish(pack_blocked_incompatible_abi, pack_id)
    Gateway --> User: pack cannot be loaded on this runtime
  end
 end
 == Usage Phase ==
  cap_router-> PM: getService<T>(pack_id)
  PM -> Registry: checkPackState(pack_id)
  Registry --> PM: Loaded / Not loaded
  alt Pack not loaded
    note over PM,Plugin
      "Loading Phase" should be initiated.
    end note
  else Pack already loaded
    note over PM,Registry
      Existing loaded instance is reused.
    end note
  end
  PM -> Plugin: get(pack_id)
  Plugin --> PM: PackHandle<T>
  PM -> AIPack: service.method(userQuery)
  AIPack --> PM: result
  PM --> cap_router: publish(response, pack_id)
  cap_router --> Gateway: response()
  Gateway --> User: result / inference
 == Unload Phase ==
 meter -> PM: deactivate(pack_id)
 PM -> PM: unloadPack(pack_id)
 PM -> Registry: checkPackState(pack_id)
 Registry --> PM: Loaded / Not loaded
 PM -> Plugin: destroyPlugin(pack_id)
 Plugin -> AIPack: destroy()
 AIPack --> Plugin: destroyed
 Plugin --> PM: unloaded
 PM -> Registry: updateStatus(pack_id, Unloaded)
 Registry --> PM: OK
 PM --> cap_router: publish(pack_unloaded, pack_id)
 cap_router --> Gateway: response(pack_unloaded)
 == Disable Phase ==
 Gateway -> PM: disablePack(pack_id)
 PM -> Registry: checkPackState(pack_id)
 Registry --> PM: Loaded / Not loaded
 opt Pack currently loaded
   note over PM,Plugin
     If pack is loaded, initiate "Unload Phase" first.
   end note
 end
 PM -> Registry: updateStatus(pack_id, Disabled)
 Registry --> PM: OK
 PM --> Gateway: publish(pack_disabled, pack_id)
 == Uninstallation Phase ==
 Gateway -> PM: uninstallPack(pack_id)
 PM -> Registry: checkPackState(pack_id)
 Registry --> PM: Installed / Already uninstalled
 alt Already uninstalled
   PM --> Gateway: packAlreadyUninstalled()
   Gateway --> User: uninstallSkipped()
 else Installed
   opt Pack currently loaded
     note over PM,Plugin
       If pack is loaded, initiate "Unload Phase" before uninstall.
     end note
   end
   PM -> Registry: findDependencies(pack_id)
   Registry --> PM: dependency list
   loop For each dependency
     PM -> PM: uninstall(dependency_id)
     PM -> Registry: unregisterPack(dependency_id)
     Registry --> PM: OK
   end
   PM -> PM: uninstall(pack_id)
   PM -> Registry: unregisterPack(pack_id)
   Registry --> PM: OK
   PM --> Gateway: publish(pack_uninstalled, pack_id)
   Gateway --> User: uninstallSuccess()
 end
end
@enduml
