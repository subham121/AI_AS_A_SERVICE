{
  "pack_id": "next_word_pack",
  "name": "Next Word Predictor",
  "version": "1.0.0",
  "intent": "next_word_prediction",
  "license": "MIT",
  "metering_unit": "prediction",
  "entrypoint": {
    "library": "lib/libnext_word_pack.so",
    "default_config": "config/default.json"
  },
  "device_capability": {
    "architecture": ["arm64", "x86_64"],
    "min_ram_mb": 128,
    "os_family": ["linux", "darwin"],
    "accelerators": []
  },
  "ai_capability": {
    "task": "next_word_prediction",
    "languages": ["en"],
    "max_context_tokens": 1,
    "model_format": "onnx",
    "keywords": ["next word", "word prediction", "autocomplete"]
  },
  "dependencies": [],
  "services": ["activate", "configure", "predict", "deactivate"],
  "tags": ["next-word", "autocomplete", "onnx", "toy", "plugin"],
  "runtime": {
    "model": "model/next_word_bigram.onnx",
    "vocab": "model/vocab.json",
    "transitions": "model/transitions.json",
    "backend": "onnxruntime",
    "fallback_backend": "transition_table",
    "input_name": "input_token",
    "output_name": "next_token",
    "lazy_load": true,
    "warmup_on_activate": true,
    "max_concurrent_inferences": 1,
    "session": {
      "intra_op_threads": 1,
      "inter_op_threads": 1,
      "graph_optimization": "extended"
    }
  }
}
