@startuml
title PackManager Lifecycle Sequence - High Level
autonumber
hide footbox

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 24
skinparam BoxPadding 12

actor User
participant "AI Gateway" as Gateway
participant "Intent + Capability\nServices" as Discovery
participant "Pack Catalog\n(PackProvider + PackRegistry + Cloud Pack Repo)" as Catalog
participant "PackManager" as PM
participant "Pack Runtime\n(PackPlugin + AI Pack)" as Runtime
participant "Metering" as Metering

group LEVEL 1 - DISCOVERY AND SELECTION
  User -> Gateway: Submit user query
  Gateway -> PM: Initialize PackManager context
  PM --> Gateway: Initialized
  Gateway -> Discovery: Identify intent and check capability
  Discovery --> Gateway: Capability result

  alt Service not supported
    Gateway --> User: Unable to serve request
  else Service supported
    Gateway -> Catalog: Collect device-compatible packs\n(local + cloud)
    Catalog --> Gateway: Compatible pack list
    Gateway --> User: Present pack options
    User -> Gateway: Select pack(pack_id)
  end
end

group LEVEL 2 - INSTALL
  Gateway -> PM: Install pack if not already registered
  opt Installation required
    PM -> Catalog: Fetch package and dependency info
    Catalog --> PM: Package content
    PM --> Gateway: Request dependency approval if needed
    Gateway --> User: Ask for install permission
    User -> Gateway: Permission granted
    Gateway -> PM: Continue installation
    PM --> Gateway: Pack installed and registered
  end
end

group LEVEL 3 - ENABLE
  Gateway -> PM: Enable pack for user
  PM --> Gateway: Pack enabled
end

group LEVEL 4 - LOAD
  Gateway -> PM: Load pack for user session
  PM -> Runtime: Initialize runtime
  Runtime --> PM: Runtime ready
  PM --> Gateway: Pack loaded
  Gateway -> Metering: Start metering for user
  Metering --> Gateway: Metering active
end

group LEVEL 5 - USAGE
  Gateway -> Metering: Validate token allowance
  Metering --> Gateway: Service allowed / denied

  alt Tokens not available
    Gateway --> User: Deny service access
  else Tokens available
    Gateway -> PM: Get pack service handle
    PM -> Runtime: Get active pack instance
    Runtime --> PM: Service handle
    PM --> Gateway: Service handle ready
    Gateway -> Runtime: Execute user request
    Runtime --> Gateway: Result and token usage
    Gateway -> Metering: Deduct consumed tokens
    Metering --> Gateway: Updated balance
    Gateway --> User: Return inference/result
  end
end

group LEVEL 6 - UNLOAD
  Gateway -> PM: Unload pack from user session
  PM -> Runtime: Stop runtime instance
  Runtime --> PM: Runtime unloaded
  PM --> Gateway: Pack unloaded
  Gateway -> Metering: Pause metering
  Metering --> Gateway: Metering paused
end

group LEVEL 7 - DISABLE
  Gateway -> PM: Disable pack for user
  PM --> Gateway: Pack disabled
end

group LEVEL 8 - UNINSTALL
  Gateway -> PM: Uninstall pack if allowed
  PM --> Gateway: Request approval if shared usage exists
  Gateway --> User: Confirm uninstall if required
  User -> Gateway: Approval granted
  Gateway -> PM: Continue uninstall
  PM -> Catalog: Remove package registration and artifacts
  Catalog --> PM: Uninstall completed
  PM --> Gateway: Pack uninstalled
  Gateway --> User: Uninstall success
end

@enduml
